#include <iostream>
#include <climits>
#include <cmath>
using namespace std;

int main()
{
    int n;
    cout << "Enter number of points: ";
    cin >> n;

    int x[n], y[n];

    for (int i = 0; i < n; i++)
    {
        cout << "Enter x and y of point " << i + 1 << ": ";
        cin >> x[i] >> y[i];
    }

    double d = INT_MAX;
    int p1 = 0, p2 = 1;

    for (int i = 0; i < n - 1; i++)
    {
        for (int j = i + 1; j < n; j++)
        {
            double dist = sqrt(
                (x[i] - x[j]) * (x[i] - x[j]) +
                (y[i] - y[j]) * (y[i] - y[j])
            );

            if (dist < d)
            {
                d = dist;
                p1 = i;
                p2 = j;
            }
        }
    }

    cout << "\nClosest distance is: " << d << endl;
    cout << "Closest pair of points: ("
         << x[p1] << ", " << y[p1] << ") and ("
         << x[p2] << ", " << y[p2] << ")" << endl;

    return 0;
}
